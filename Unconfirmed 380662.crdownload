openapi: 3.0.3
info:
  title: InfraRakshak API
  version: 2.0.0
  description: |-
    Production API for the InfraRakshak school infrastructure monitoring platform.

    ## Authentication
    All endpoints (except login/register) require a JWT Bearer token.
    Obtain tokens via `POST /api/v1/auth/token/`.

    Pass the access token in the `Authorization` header:
    ```
    Authorization: Bearer <access_token>
    ```
paths:
  /api/v1/accounts/auth/logout/:
    post:
      operationId: accounts_auth_logout_create
      description: Blacklists the provided refresh token to securely end the session.
      summary: User Logout
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/LogoutRequestRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/LogoutRequestRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/LogoutRequestRequest'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '205':
          description: Token blacklisted successfully.
  /api/v1/accounts/dashboard/:
    get:
      operationId: accounts_dashboard_list
      description: Returns role-specific statistics and overview data for the authenticated
        user.
      summary: Get Dashboard Statistics
      tags:
      - Dashboard
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/Dashboard'
          description: ''
  /api/v1/accounts/onboard/bulk/:
    post:
      operationId: accounts_onboard_bulk_create
      description: Upload an Excel file to bulk-create accounts. DEOs can add Admin
        Staff, Schools can add Staff, and Superusers can add DEOs.
      summary: Bulk Onboarding (Excel)
      tags:
      - Onboarding
      requestBody:
        content:
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/BulkOnboardingRequest'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '201':
          description: Accounts created successfully
  /api/v1/accounts/profiles/admin-staff/:
    get:
      operationId: accounts_profiles_admin_staff_list
      summary: List admin staff profiles
      parameters:
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      tags:
      - Profiles
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedAdminStaffProfileList'
          description: ''
    post:
      operationId: accounts_profiles_admin_staff_create
      tags:
      - accounts
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/AdminStaffProfileRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/AdminStaffProfileRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/AdminStaffProfileRequest'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AdminStaffProfile'
          description: ''
  /api/v1/accounts/profiles/admin-staff/{id}/:
    get:
      operationId: accounts_profiles_admin_staff_retrieve
      summary: Get admin staff profile details
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this admin staff profile.
        required: true
      tags:
      - Profiles
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AdminStaffProfile'
          description: ''
    put:
      operationId: accounts_profiles_admin_staff_update
      summary: Update admin staff profile
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this admin staff profile.
        required: true
      tags:
      - Profiles
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/AdminStaffProfileRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/AdminStaffProfileRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/AdminStaffProfileRequest'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AdminStaffProfile'
          description: ''
    patch:
      operationId: accounts_profiles_admin_staff_partial_update
      summary: Partially update admin staff profile
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this admin staff profile.
        required: true
      tags:
      - Profiles
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedAdminStaffProfileRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedAdminStaffProfileRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedAdminStaffProfileRequest'
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AdminStaffProfile'
          description: ''
    delete:
      operationId: accounts_profiles_admin_staff_destroy
      summary: Delete admin staff profile
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this admin staff profile.
        required: true
      tags:
      - Profiles
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '204':
          description: No response body
