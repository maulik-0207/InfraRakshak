  /api/v1/contracts/contracts/:
    get:
      operationId: contracts_contracts_list
      description: Paginated list of contracts. Filter by status, category, priority,
        or school.
      summary: List contracts
      parameters:
      - in: query
        name: category
        schema:
          type: string
        description: Filter by category (PLUMBING, etc.)
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - in: query
        name: priority_level
        schema:
          type: string
        description: Filter by priority (LOW, MEDIUM, HIGH)
      - in: query
        name: school
        schema:
          type: integer
        description: Filter by School ID
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      - in: query
        name: status
        schema:
          type: string
        description: Filter by status (OPEN, IN_BIDDING, etc.)
      tags:
      - Contracts
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedContractListList'
          description: ''
    post:
      operationId: contracts_contracts_create
      description: |-
        Create a new infrastructure contract for a school.

        **Validation rules:**
        - `estimated_cost` must be positive
        - `bid_end_date` must be >= `bid_start_date`
        - `category`: PLUMBING | ELECTRICAL | STRUCTURAL
        - `status`: OPEN | IN_BIDDING | AWARDED | IN_PROGRESS | COMPLETED | CANCELLED
      summary: Create a new contract
      tags:
      - Contracts
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ContractListRequest'
            examples:
              CreateContract:
                value:
                  school: 1
                  title: Boys Toilet Block Plumbing Repair
                  description: Complete overhaul of plumbing in boys toilet block.
                  category: PLUMBING
                  estimated_cost: '150000.00'
                  priority_level: HIGH
                  bid_start_date: '2025-04-25'
                  bid_end_date: '2025-05-05'
                  created_by: 1
                summary: Create Contract
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/ContractListRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/ContractListRequest'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ContractList'
          description: ''
