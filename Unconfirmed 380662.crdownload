components:
  schemas:
    AdminStaffProfile:
      type: object
      description: Serializer for Admin Staff profile.
      properties:
        id:
          type: integer
          readOnly: true
        user:
          type: integer
          readOnly: true
        email:
          type: string
          format: email
          readOnly: true
        parent_deo:
          type: integer
        full_name:
          type: string
          maxLength: 255
        phone_no:
          type: string
          maxLength: 15
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - created_at
      - email
      - full_name
      - id
      - parent_deo
      - phone_no
      - updated_at
      - user
    AdminStaffProfileRequest:
      type: object
      description: Serializer for Admin Staff profile.
      properties:
        parent_deo:
          type: integer
        full_name:
          type: string
          minLength: 1
          maxLength: 255
        phone_no:
          type: string
          minLength: 1
          maxLength: 15
      required:
      - full_name
      - parent_deo
      - phone_no
    AreaTypeEnum:
      enum:
      - RURAL
      - URBAN
      - SEMI_URBAN
      type: string
      description: |-
        * `RURAL` - Rural
        * `URBAN` - Urban
        * `SEMI_URBAN` - Semi-Urban
    BuildingConditionEnum:
      enum:
      - GOOD
      - MINOR_DAMAGE
      - MAJOR_DAMAGE
      type: string
      description: |-
        * `GOOD` - Good
        * `MINOR_DAMAGE` - Minor Damage
        * `MAJOR_DAMAGE` - Major Damage
    BuildingSafetyEnum:
      enum:
      - SAFE
      - MINOR_RISK
      - UNSAFE
      type: string
      description: |-
        * `SAFE` - Safe
        * `MINOR_RISK` - Minor Risk
        * `UNSAFE` - Unsafe
    BulkOnboardingRequest:
      type: object
      description: Serializer for Excel file upload.
      properties:
        file:
          type: string
          format: binary
        role:
          $ref: '#/components/schemas/BulkOnboardingRoleEnum'
      required:
      - file
      - role
    BulkOnboardingRoleEnum:
      enum:
      - ADMIN_STAFF
      - STAFF
      - DEO
      type: string
      description: |-
        * `ADMIN_STAFF` - ADMIN_STAFF
        * `STAFF` - STAFF
        * `DEO` - DEO
    CategoryEnum:
      enum:
      - PLUMBING
      - ELECTRICAL
      - STRUCTURAL
      type: string
      description: |-
        * `PLUMBING` - Plumbing
        * `ELECTRICAL` - Electrical
        * `STRUCTURAL` - Structural
    ContractAssignment:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        contract:
          type: integer
        contractor:
          type: integer
        bid:
          type: integer
        final_amount:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
        final_deadline:
          type: string
          format: date
        assigned_at:
          type: string
          format: date-time
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - assigned_at
      - bid
      - contract
      - contractor
      - created_at
      - final_amount
      - final_deadline
      - id
    ContractAssignmentRequest:
      type: object
      properties:
        contract:
          type: integer
        contractor:
          type: integer
        bid:
          type: integer
        final_amount:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
        final_deadline:
          type: string
          format: date
      required:
      - bid
      - contract
      - contractor
      - final_amount
      - final_deadline
    ContractBid:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        contract:
          type: integer
        contractor:
          type: integer
        bid_amount:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
        estimated_days:
          type: integer
          maximum: 2147483647
          minimum: 0
          description: Estimated number of days to complete the work.
        proposal_text:
          type: string
        status:
          $ref: '#/components/schemas/ContractBidStatusEnum'
        status_display:
          type: string
          readOnly: true
        submitted_at:
          type: string
          format: date-time
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - bid_amount
      - contract
      - contractor
      - created_at
      - estimated_days
      - id
      - status_display
      - submitted_at
    ContractBidRequest:
      type: object
      properties:
        contract:
          type: integer
        contractor:
          type: integer
        bid_amount:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
        estimated_days:
          type: integer
          maximum: 2147483647
          minimum: 0
          description: Estimated number of days to complete the work.
        proposal_text:
          type: string
        status:
          $ref: '#/components/schemas/ContractBidStatusEnum'
      required:
      - bid_amount
      - contract
      - contractor
      - estimated_days
    ContractBidStatusEnum:
      enum:
      - PENDING
      - ACCEPTED
      - REJECTED
      - WITHDRAWN
      type: string
      description: |-
        * `PENDING` - Pending
        * `ACCEPTED` - Accepted
        * `REJECTED` - Rejected
        * `WITHDRAWN` - Withdrawn
    ContractDetail:
      type: object
      description: Full contract with nested lifecycle data for detail view.
      properties:
        id:
          type: integer
          readOnly: true
        school:
          type: integer
        prediction_report:
          type: integer
          nullable: true
          description: The prediction report that triggered this contract.
        title:
          type: string
          maxLength: 255
        description:
          type: string
        category:
          $ref: '#/components/schemas/CategoryEnum'
        category_display:
          type: string
          readOnly: true
        estimated_cost:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
        priority_level:
          $ref: '#/components/schemas/PriorityLevelEnum'
        priority_display:
          type: string
          readOnly: true
        status:
          $ref: '#/components/schemas/StatusF0cEnum'
        status_display:
          type: string
          readOnly: true
        bid_start_date:
          type: string
          format: date
          nullable: true
        bid_end_date:
          type: string
          format: date
          nullable: true
        created_by:
          type: integer
          description: Admin or DEO who created this contract.
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
        bids:
          type: array
          items:
            $ref: '#/components/schemas/ContractBid'
          readOnly: true
        assignment:
          allOf:
          - $ref: '#/components/schemas/ContractAssignment'
          readOnly: true
        progress_updates:
          type: array
          items:
            $ref: '#/components/schemas/WorkProgress'
          readOnly: true
        proofs:
          type: array
          items:
            $ref: '#/components/schemas/WorkProof'
          readOnly: true
        verifications:
          type: array
          items:
            $ref: '#/components/schemas/WorkVerification'
          readOnly: true
        payments:
          type: array
          items:
            $ref: '#/components/schemas/ContractPayment'
          readOnly: true
      required:
      - assignment
      - bids
      - category
      - category_display
      - created_at
      - created_by
      - estimated_cost
      - id
      - payments
      - priority_display
      - progress_updates
      - proofs
      - school
      - status_display
      - title
      - updated_at
      - verifications
    ContractList:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        school:
          type: integer
        prediction_report:
          type: integer
          nullable: true
          description: The prediction report that triggered this contract.
        title:
          type: string
          maxLength: 255
        description:
          type: string
        category:
          $ref: '#/components/schemas/CategoryEnum'
        category_display:
          type: string
          readOnly: true
        estimated_cost:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
        priority_level:
          $ref: '#/components/schemas/PriorityLevelEnum'
        priority_display:
          type: string
          readOnly: true
        status:
          $ref: '#/components/schemas/StatusF0cEnum'
        status_display:
          type: string
          readOnly: true
        bid_start_date:
          type: string
          format: date
          nullable: true
        bid_end_date:
          type: string
          format: date
          nullable: true
        created_by:
          type: integer
          description: Admin or DEO who created this contract.
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - category
      - category_display
      - created_at
      - created_by
      - estimated_cost
      - id
      - priority_display
      - school
      - status_display
      - title
    ContractListRequest:
      type: object
      properties:
        school:
          type: integer
        prediction_report:
          type: integer
          nullable: true
          description: The prediction report that triggered this contract.
        title:
          type: string
          minLength: 1
          maxLength: 255
        description:
          type: string
        category:
          $ref: '#/components/schemas/CategoryEnum'
        estimated_cost:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
        priority_level:
          $ref: '#/components/schemas/PriorityLevelEnum'
        status:
          $ref: '#/components/schemas/StatusF0cEnum'
        bid_start_date:
          type: string
          format: date
          nullable: true
        bid_end_date:
          type: string
          format: date
          nullable: true
        created_by:
          type: integer
          description: Admin or DEO who created this contract.
      required:
      - category
      - created_by
      - estimated_cost
      - school
      - title
    ContractPayment:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        contract:
          type: integer
        amount:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
        payment_status:
          $ref: '#/components/schemas/PaymentStatusEnum'
        status_display:
          type: string
          readOnly: true
        transaction_reference:
          type: string
          description: Bank or UPI transaction reference number.
          maxLength: 255
        paid_at:
          type: string
          format: date-time
          nullable: true
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - amount
      - contract
      - created_at
      - id
      - status_display
    ContractPaymentRequest:
      type: object
      properties:
        contract:
          type: integer
        amount:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
        payment_status:
          $ref: '#/components/schemas/PaymentStatusEnum'
        transaction_reference:
          type: string
          description: Bank or UPI transaction reference number.
          maxLength: 255
        paid_at:
          type: string
          format: date-time
          nullable: true
      required:
      - amount
      - contract
    ContractorProfile:
      type: object
      description: Serializer for Contractor profile.
      properties:
        id:
          type: integer
          readOnly: true
        user:
          type: integer
          readOnly: true
        email:
          type: string
          format: email
          readOnly: true
        company_name:
          type: string
          maxLength: 255
        license_number:
          type: string
          maxLength: 100
        phone_no:
          type: string
          maxLength: 15
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - company_name
      - created_at
      - email
      - id
      - license_number
      - phone_no
      - updated_at
      - user
    ContractorProfileRequest:
      type: object
      description: Serializer for Contractor profile.
      properties:
        company_name:
          type: string
          minLength: 1
          maxLength: 255
        license_number:
          type: string
          minLength: 1
          maxLength: 100
        phone_no:
          type: string
          minLength: 1
          maxLength: 15
      required:
      - company_name
      - license_number
      - phone_no
    ContractorRegistrationRequest:
      type: object
      description: Serializer for Contractor self-registration.
      properties:
        email:
          type: string
          format: email
          minLength: 1
        password:
          type: string
          writeOnly: true
          minLength: 8
        company_name:
          type: string
          minLength: 1
        license_number:
          type: string
          minLength: 1
        phone_no:
          type: string
          minLength: 1
      required:
      - company_name
      - email
      - license_number
      - password
      - phone_no
    CustomTokenObtainPairRequest:
      type: object
      description: Overridden JWT serializer to include role and dashboard redirects.
      properties:
        email:
          type: string
          writeOnly: true
          minLength: 1
        password:
          type: string
          writeOnly: true
          minLength: 1
      required:
      - email
      - password
    DEOProfile:
      type: object
      description: Serializer for DEO profile.
      properties:
        id:
          type: integer
          readOnly: true
        user:
          type: integer
          readOnly: true
        email:
          type: string
          format: email
          readOnly: true
        district:
          type: string
          maxLength: 100
        office_address:
          type: string
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - created_at
      - district
      - email
      - id
      - office_address
      - updated_at
      - user
    DEOProfileRequest:
      type: object
      description: Serializer for DEO profile.
      properties:
        district:
          type: string
          minLength: 1
          maxLength: 100
        office_address:
          type: string
          minLength: 1
      required:
      - district
      - office_address
    Dashboard:
      type: object
      description: Serializer for dashboard summary response.
      properties:
        role:
          type: string
        email:
          type: string
          format: email
        stats:
          type: object
          additionalProperties:
            type: integer
      required:
      - email
      - role
      - stats
    DistrictReport:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        district:
          type: string
          maxLength: 100
        week_start_date:
          type: string
          format: date
        week_end_date:
          type: string
          format: date
        total_schools:
          type: integer
          maximum: 2147483647
          minimum: 0
        high_risk_schools:
          type: integer
          maximum: 2147483647
          minimum: 0
        medium_risk_schools:
          type: integer
          maximum: 2147483647
          minimum: 0
        low_risk_schools:
          type: integer
          maximum: 2147483647
          minimum: 0
        avg_score:
          type: number
          format: double
        generated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - district
      - generated_at
      - id
      - week_end_date
      - week_start_date
    DistrictReportRequest:
      type: object
