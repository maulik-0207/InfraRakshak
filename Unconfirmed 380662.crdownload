      - submitted_by_name
    SchoolRequest:
      type: object
      description: Read/write serializer for schools.
      properties:
        udise_code:
          type: string
          minLength: 1
          description: Government-issued unique school identifier.
          maxLength: 20
        name:
          type: string
          minLength: 1
          maxLength: 255
        address:
          type: string
          minLength: 1
        district:
          type: string
          minLength: 1
          maxLength: 100
        block:
          type: string
          maxLength: 100
        cluster:
          type: string
          maxLength: 100
        pincode:
          type: string
          minLength: 1
          maxLength: 10
        latitude:
          type: string
          format: decimal
          pattern: ^-?\d{0,3}(?:\.\d{0,7})?$
          nullable: true
        longitude:
          type: string
          format: decimal
          pattern: ^-?\d{0,3}(?:\.\d{0,7})?$
          nullable: true
        school_type:
          $ref: '#/components/schemas/SchoolTypeEnum'
        weather_zone:
          $ref: '#/components/schemas/WeatherZoneEnum'
        material_type:
          $ref: '#/components/schemas/MaterialTypeEnum'
        building_age:
          type: integer
          maximum: 2147483647
          minimum: 0
          description: Age of the school building in years.
        is_girls_school:
          type: boolean
          description: Whether the school is specifically for girls (impacts priority
            weights).
        flood_prone_area:
          type: boolean
          description: Whether the school is in a geo-spatially identified flood zone.
      required:
      - address
      - district
      - name
      - pincode
      - udise_code
    SchoolSelfRegistrationRequest:
      type: object
      description: Serializer for School self-registration.
      properties:
        email:
          type: string
          format: email
          minLength: 1
        password:
          type: string
          writeOnly: true
          minLength: 8
        udise_code:
          type: string
          minLength: 1
        school_name:
          type: string
          minLength: 1
        phone_no:
          type: string
          minLength: 1
        district:
          type: string
          minLength: 1
        address:
          type: string
          minLength: 1
        school_type:
          type: string
          minLength: 1
      required:
      - address
      - district
      - email
      - password
      - phone_no
      - school_name
      - school_type
      - udise_code
