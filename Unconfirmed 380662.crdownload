      summary: List payments
      parameters:
      - in: query
        name: contract
        schema:
          type: integer
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - in: query
        name: payment_status
        schema:
          type: string
          enum:
          - PAID
          - PARTIAL
          - PENDING
        description: |-
          * `PENDING` - Pending
          * `PARTIAL` - Partial
          * `PAID` - Paid
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      tags:
      - Contracts
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedContractPaymentList'
          description: ''
    post:
      operationId: contracts_payments_create
      description: '`amount` must be positive. Status: PENDING | PARTIAL | PAID.'
      summary: Record payment
      tags:
      - Contracts
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ContractPaymentRequest'
            examples:
              RecordPayment:
                value:
                  contract: 1
                  amount: '75000.00'
                  payment_status: PARTIAL
                  transaction_reference: UPI-REF-20250418-001
                  paid_at: '2025-04-18T10:30:00Z'
                summary: Record Payment
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/ContractPaymentRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/ContractPaymentRequest'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ContractPayment'
          description: ''
