    ElectricalRiskLevelEnum:
      enum:
      - LOW
      - MEDIUM
      - HIGH
      type: string
      description: |-
        * `LOW` - Low
        * `MEDIUM` - Medium
        * `HIGH` - High
    FileTypeEnum:
      enum:
      - IMAGE
      - VIDEO
      - DOCUMENT
      type: string
      description: |-
        * `IMAGE` - Image
        * `VIDEO` - Video
        * `DOCUMENT` - Document
    IssueTypeEnum:
      enum:
      - PLUMBING
      - ELECTRICAL
      - STRUCTURAL
      type: string
      description: |-
        * `PLUMBING` - Plumbing
        * `ELECTRICAL` - Electrical
        * `STRUCTURAL` - Structural
    LightingConditionEnum:
      enum:
      - GOOD
      - AVERAGE
      - POOR
      type: string
      description: |-
        * `GOOD` - Good
        * `AVERAGE` - Average
        * `POOR` - Poor
    LogoutRequestRequest:
      type: object
      description: Serializer for blacklisting a refresh token.
      properties:
        refresh:
          type: string
          minLength: 1
          description: The refresh token to blacklist.
      required:
      - refresh
    MaterialTypeEnum:
      enum:
      - Brick
      - Mixed
      - RCC
      - Temporary
      type: string
      description: |-
        * `Brick` - Brick
        * `Mixed` - Mixed
        * `RCC` - RCC
        * `Temporary` - Temporary
    Notification:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        user:
          type: integer
        title:
          type: string
          maxLength: 255
        message:
          type: string
        type:
