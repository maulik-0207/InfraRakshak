  /api/v1/contracts/progress/:
    get:
      operationId: contracts_progress_list
      description: CRUD for work progress updates on contracts.
      summary: List progress updates
      parameters:
      - in: query
        name: contract
        schema:
          type: integer
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      - in: query
        name: status
        schema:
          type: string
          enum:
          - COMPLETED
          - IN_PROGRESS
          - NOT_STARTED
          - ON_HOLD
        description: |-
          * `NOT_STARTED` - Not Started
          * `IN_PROGRESS` - In Progress
          * `ON_HOLD` - On Hold
          * `COMPLETED` - Completed
      tags:
      - Contracts
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedWorkProgressList'
          description: ''
    post:
      operationId: contracts_progress_create
      description: '`progress_percentage` must be 0–100.'
      summary: Submit progress update
      tags:
      - Contracts
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/WorkProgressRequest'
            examples:
              ProgressUpdate:
                value:
                  contract: 1
                  progress_percentage: 45
                  status: IN_PROGRESS
                  update_note: Pipe replacement 45% complete. New fixtures installed.
                  updated_by: 1
                summary: Progress Update
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/WorkProgressRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/WorkProgressRequest'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/WorkProgress'
          description: ''
