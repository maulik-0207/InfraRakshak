          format: double
          description: Maximum crack width measured in millimeters (required for ML
            structural model).
        toilet_cleanliness:
          type: integer
          maximum: 32767
          minimum: 0
          description: Rating 1 (worst) to 5 (best).
        campus_cleanliness:
          type: integer
          maximum: 32767
          minimum: 0
          description: Rating 1 (worst) to 5 (best).
        inspection_score:
          type: number
          format: double
          nullable: true
          description: Auto-computed or manually entered overall score.
        submitted_by:
          type: integer
      required:
      - school
      - submitted_by
      - survey_date
