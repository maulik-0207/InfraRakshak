  /api/v1/accounts/register/contractor/:
    post:
      operationId: accounts_register_contractor_create
      description: Public endpoint for contractors to register their own account and
        company profile.
      summary: Contractor Self-Registration
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ContractorRegistrationRequest'
            examples:
              ContractorRegistration:
                value:
                  email: contact@buildwell_infra.com
                  password: SecurePassword123
                  company_name: BuildWell Infra Pvt Ltd
                  license_number: LIC-2024-001
                  phone_no: '9988776655'
                summary: Contractor Registration
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/ContractorRegistrationRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/ContractorRegistrationRequest'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      - {}
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/UserList'
              examples:
                ContractorRegistration:
                  value:
                    email: contact@buildwell_infra.com
                    password: SecurePassword123
                    company_name: BuildWell Infra Pvt Ltd
                    license_number: LIC-2024-001
                    phone_no: '9988776655'
                  summary: Contractor Registration
          description: ''
  /api/v1/accounts/register/school/:
    post:
      operationId: accounts_register_school_create
      description: Public endpoint for schools to register their own account. Password
        must be at least 8 characters.
      summary: School Self-Registration
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/SchoolSelfRegistrationRequest'
            examples:
              SchoolRegistration:
                value:
                  email: principal@mg_highschool.edu
                  password: SecurePassword123
                  school_id: SCH-00123
                  school_name: Mahatma Gandhi High School
                  phone_no: '9876543210'
                  district: Ahmedabad
                  address: 123 Education Square, Main St
                  school_type: Secondary
                summary: School Registration
