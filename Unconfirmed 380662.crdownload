  /api/v1/schools/infrastructure/:
    get:
      operationId: schools_infrastructure_list
      description: Returns all infrastructure survey records. Filter by school or
        date.
      summary: List infrastructure surveys
      parameters:
      - in: query
        name: building_condition
        schema:
          type: string
          enum:
          - GOOD
          - MAJOR_DAMAGE
          - MINOR_DAMAGE
        description: |-
          * `GOOD` - Good
          * `MINOR_DAMAGE` - Minor Damage
          * `MAJOR_DAMAGE` - Major Damage
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
