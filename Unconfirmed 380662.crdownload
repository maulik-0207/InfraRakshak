        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedSchoolProfileList'
          description: ''
    post:
      operationId: schools_profiles_create
      description: |-
        Create a demographic profile for a school.

        **Validation rules:**
        - `total_boys + total_girls` <= `total_students`
        - `functional_classrooms` <= `classrooms_count`
      summary: Create school profile
      tags:
      - Schools
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/SchoolProfileRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/SchoolProfileRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/SchoolProfileRequest'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SchoolProfile'
          description: ''
