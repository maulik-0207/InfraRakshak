      type: object
      description: Serializer for Admin Staff profile.
      properties:
        parent_deo:
          type: integer
        full_name:
          type: string
          minLength: 1
          maxLength: 255
        phone_no:
          type: string
          minLength: 1
          maxLength: 15
    PatchedContractAssignmentRequest:
      type: object
      properties:
        contract:
          type: integer
        contractor:
          type: integer
        bid:
          type: integer
        final_amount:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
        final_deadline:
          type: string
          format: date
    PatchedContractBidRequest:
      type: object
      properties:
        contract:
          type: integer
        contractor:
          type: integer
        bid_amount:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
        estimated_days:
          type: integer
          maximum: 2147483647
          minimum: 0
          description: Estimated number of days to complete the work.
        proposal_text:
          type: string
        status:
          $ref: '#/components/schemas/ContractBidStatusEnum'
    PatchedContractListRequest:
      type: object
      properties:
        school:
          type: integer
        prediction_report:
          type: integer
          nullable: true
          description: The prediction report that triggered this contract.
        title:
          type: string
          minLength: 1
          maxLength: 255
        description:
          type: string
        category:
          $ref: '#/components/schemas/CategoryEnum'
        estimated_cost:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
        priority_level:
          $ref: '#/components/schemas/PriorityLevelEnum'
        status:
          $ref: '#/components/schemas/StatusF0cEnum'
        bid_start_date:
          type: string
          format: date
          nullable: true
        bid_end_date:
          type: string
          format: date
          nullable: true
        created_by:
          type: integer
          description: Admin or DEO who created this contract.
    PatchedContractPaymentRequest:
      type: object
      properties:
        contract:
          type: integer
        amount:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
        payment_status:
          $ref: '#/components/schemas/PaymentStatusEnum'
        transaction_reference:
          type: string
          description: Bank or UPI transaction reference number.
          maxLength: 255
        paid_at:
          type: string
          format: date-time
          nullable: true
    PatchedContractorProfileRequest:
