      operationId: reports_weekly_reports_update
      description: |-
        CRUD for weekly infrastructure reports.

        The detail view includes nested sub-reports (plumbing, electrical,
        structural) and all associated issues.

        **Recommended query optimization:**
        Use `?expand=true` for nested data (detail view auto-expands).
      summary: Update weekly report
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this Weekly Report.
        required: true
      tags:
      - Reports
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/WeeklyReportListRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/WeeklyReportListRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/WeeklyReportListRequest'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/WeeklyReportList'
          description: ''
    patch:
      operationId: reports_weekly_reports_partial_update
      description: |-
        CRUD for weekly infrastructure reports.

        The detail view includes nested sub-reports (plumbing, electrical,
        structural) and all associated issues.

        **Recommended query optimization:**
        Use `?expand=true` for nested data (detail view auto-expands).
      summary: Partially update weekly report
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this Weekly Report.
        required: true
      tags:
      - Reports
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedWeeklyReportListRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedWeeklyReportListRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedWeeklyReportListRequest'
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/WeeklyReportList'
          description: ''
    delete:
      operationId: reports_weekly_reports_destroy
      description: |-
        CRUD for weekly infrastructure reports.

        The detail view includes nested sub-reports (plumbing, electrical,
        structural) and all associated issues.

        **Recommended query optimization:**
        Use `?expand=true` for nested data (detail view auto-expands).
      summary: Delete weekly report
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this Weekly Report.
        required: true
      tags:
