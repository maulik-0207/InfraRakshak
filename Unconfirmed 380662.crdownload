  /api/v1/reports/weekly-reports/:
    get:
      operationId: reports_weekly_reports_list
      description: Paginated list of weekly reports. Filter by school, status, or
        date range.
      summary: List weekly reports
      parameters:
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - in: query
        name: school
        schema:
          type: integer
        description: Filter by School ID
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      - in: query
        name: status
        schema:
          type: string
        description: Filter by status (DRAFT, SUBMITTED, REVIEWED)
      - in: query
        name: week_start_date
        schema:
          type: string
        description: Filter by start date (YYYY-MM-DD)
      tags:
      - Reports
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedWeeklyReportListList'
          description: ''
    post:
      operationId: reports_weekly_reports_create
      description: |-
        Create a new weekly report for a school.

        **Constraints:**
        - Unique per `(school, week_start_date, week_end_date)`
        - `week_end_date` must be >= `week_start_date`
      summary: Create weekly report
      tags:
      - Reports
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/WeeklyReportListRequest'
            examples:
              CreateWeeklyReport:
                value:
                  school: 1
                  week_start_date: '2025-04-14'
                  week_end_date: '2025-04-20'
                  status: DRAFT
                  remarks: First inspection of the month.
                summary: Create Weekly Report
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/WeeklyReportListRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/WeeklyReportListRequest'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/WeeklyReportList'
          description: ''
  /api/v1/reports/weekly-reports/{id}/:
    get:
      operationId: reports_weekly_reports_retrieve
      description: Returns the full weekly report including nested plumbing, electrical,
        structural sub-reports and issues.
      summary: Get weekly report with sub-reports
      parameters:
      - in: path
        name: id
