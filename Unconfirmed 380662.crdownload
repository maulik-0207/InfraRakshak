    WorkProof:
      type: object
      description: |-
        Serializer for work proof file uploads.

        Accepts multipart/form-data with file upload.
        File constraints: max 10MB, allowed types: jpg, png, gif, mp4, pdf, doc, docx.
      properties:
        id:
          type: integer
          readOnly: true
        contract:
          type: integer
        file:
          type: string
          format: uri
          description: Upload image, video, or document as proof of work.
        file_url:
          type: string
          nullable: true
          description: Return the absolute URL for the uploaded file.
          readOnly: true
        file_type:
          $ref: '#/components/schemas/FileTypeEnum'
        file_type_display:
          type: string
          readOnly: true
        description:
          type: string
        uploaded_by:
          type: integer
        uploaded_at:
          type: string
          format: date-time
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - contract
      - created_at
      - file
      - file_type
      - file_type_display
      - file_url
      - id
      - uploaded_at
      - uploaded_by
    WorkProofRequest:
      type: object
      description: |-
        Serializer for work proof file uploads.

        Accepts multipart/form-data with file upload.
        File constraints: max 10MB, allowed types: jpg, png, gif, mp4, pdf, doc, docx.
      properties:
        contract:
          type: integer
        file:
          type: string
          format: binary
          description: Upload image, video, or document as proof of work.
        file_type:
          $ref: '#/components/schemas/FileTypeEnum'
        description:
          type: string
        uploaded_by:
          type: integer
      required:
      - contract
      - file
      - file_type
      - uploaded_by
    WorkVerification:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        contract:
          type: integer
        verified_by:
          type: integer
          description: DEO or official who verified the work.
        verification_status:
          $ref: '#/components/schemas/VerificationStatusEnum'
        status_display:
          type: string
          readOnly: true
        remarks:
          type: string
        verified_at:
          type: string
          format: date-time
          nullable: true
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - contract
      - created_at
      - id
      - status_display
      - verified_by
    WorkVerificationRequest:
      type: object
      properties:
        contract:
          type: integer
        verified_by:
          type: integer
          description: DEO or official who verified the work.
        verification_status:
          $ref: '#/components/schemas/VerificationStatusEnum'
        remarks:
          type: string
        verified_at:
          type: string
          format: date-time
          nullable: true
      required:
      - contract
      - verified_by
  securitySchemes:
    cookieAuth:
      type: apiKey
      in: cookie
      name: sessionid
    jwtAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT
tags:
- name: Auth
  description: Authentication & token management
- name: Accounts
  description: User profiles and role management
- name: Schools
  description: School, profile, and infrastructure data
- name: Reports
  description: Weekly infrastructure reports
- name: Predictions
  description: ML-driven risk predictions and district reports
- name: Contracts
  description: 'Contract lifecycle: bidding, assignment, progress, payment'
- name: Notifications
  description: In-app user notifications
